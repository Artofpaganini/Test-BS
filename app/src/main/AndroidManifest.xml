<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BsZorderLab">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BsZorderLab">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Demo XBottomSheet: отдельная exported-Activity со своим LAUNCHER (вторая иконка «XBS Demo»),
             adjustResize + edge-to-edge для IME. Полное имя вне namespace com.zorderlab. Блок additive. -->
        <activity
            android:name="com.onexui.demo.XbsDemoActivity"
            android:exported="true"
            android:label="XBS Demo"
            android:theme="@style/Theme.BsZorderLab"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
