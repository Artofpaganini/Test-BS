<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BsZorderLab">

        <!-- Единственный LAUNCHER: UI-развилка между z-order-лабой (MainActivity) и XBS Demo. -->
        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:theme="@style/Theme.BsZorderLab">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Z-order-лаба (кнопки 1-8). exported оставлен: прямой запуск adb am start работает по-прежнему. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BsZorderLab" />

        <!-- Demo XBottomSheet (кейсы a-k), adjustResize + edge-to-edge для IME. Полное имя вне namespace
             com.zorderlab. exported оставлен: прямой запуск adb am start работает по-прежнему. -->
        <activity
            android:name="com.onexui.demo.XbsDemoActivity"
            android:exported="true"
            android:label="XBS Demo"
            android:theme="@style/Theme.BsZorderLab"
            android:windowSoftInputMode="adjustResize" />
    </application>
</manifest>
