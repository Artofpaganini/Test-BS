<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Системные пермишены проекта. Все ниже — dangerous: помимо декларации требуют рантайм-запроса
         (Android 6+) перед использованием; здесь только объявление (по запросу — без рантайм-инфраструктуры). -->
    <!-- Нотификации (Android 13+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Камера. -->
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Медиа (Android 13+): изображения и видео. -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_VIDEO" />
    <!-- Хранилище (Android 12 и ниже): на 13+ заменено READ_MEDIA_*, поэтому ограничено maxSdkVersion. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.BsZorderLab">

        <!-- Единственный LAUNCHER: UI-развилка между z-order-лабой (MainActivity) и XBS Demo. -->
        <activity
            android:name=".LauncherActivity"
            android:exported="true"
            android:theme="@style/Theme.BsZorderLab">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Z-order-лаба (кнопки 1-8). exported оставлен: прямой запуск adb am start работает по-прежнему. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BsZorderLab" />

        <!-- Demo XBottomSheet (кейсы a-k), adjustResize + edge-to-edge для IME. Полное имя вне namespace
             com.zorderlab. exported оставлен: прямой запуск adb am start работает по-прежнему. -->
        <activity
            android:name="com.onexui.demo.XbsDemoActivity"
            android:exported="true"
            android:label="XBS Demo"
            android:theme="@style/Theme.BsZorderLab"
            android:windowSoftInputMode="adjustResize" />
    </application>
</manifest>
